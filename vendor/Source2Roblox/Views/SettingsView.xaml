<Page x:Class="Source2Roblox.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="SettingsView"
      >
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Padding="28,20,28,28">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <TextBlock Name="SettingsTitleLabel"
                           Text="Settings"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock Text="Manage appearance, language, and conversion preferences."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,24" />

                <ui:Card Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Name="VisualOptionsLabel"
                                   Text="Visual &amp; Language"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,18" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="LanguageLabel"
                                           Text="App Language"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="LanguageDescLabel"
                                           Text="Choose the UI display language."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Name="LanguageComboBox"
                                      Grid.Column="1"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="ThemeLabel"
                                           Text="Theme"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="ThemeDescLabel"
                                           Text="Light, Dark, or follow system default."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Name="ThemeComboBox"
                                      Grid.Column="1"
                                      VerticalAlignment="Center" />
                        </Grid>

                    </StackPanel>
                </ui:Card>
                <ui:Card Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Name="CustomTexturesLabel"
                                   Text="Custom Textures Folder"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <TextBlock Name="CustomTexturesDescLabel"
                                   Text="Override or extend default game textures during conversion."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Name="CustomTexturesTextBox"
                                        PlaceholderText="Select a custom textures folder..."
                                        Grid.Column="0"
                                        VerticalAlignment="Center" />
                            <ui:Button Name="BrowseCustomTexturesButton"
                                       Content="Browse"
                                       Icon="Folder24"
                                       Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Click="BrowseCustomTexturesButton_Click" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
                <ui:Card Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Name="RobloxUploadLabel"
                                   Text="Roblox Cloud Upload"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="UploadAssetsLabel"
                                           Text="Upload Textures"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="UploadAssetsDescLabel"
                                           Text="Upload VTF textures directly to Roblox and bind via Asset ID."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Name="UploadAssetsToggle"
                                             Grid.Column="1"
                                             VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="UploadMeshesLabel"
                                           Text="Upload Meshes"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="UploadMeshesDescLabel"
                                           Text="Upload .mesh geometry directly to Roblox and bind via Asset ID."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ui:ToggleSwitch Name="UploadMeshesToggle"
                                             Grid.Column="1"
                                             VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="ApiKeyLabel"
                                           Text="API Key"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="ApiKeyDescLabel"
                                           Text="Roblox Open Cloud API Key with Asset Write permissions."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ui:TextBox Name="ApiKeyTextBox"
                                        Grid.Column="1"
                                        VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="CreatorTypeLabel"
                                           Text="Creator Type"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="CreatorTypeDescLabel"
                                           Text="Identify assets as User-owned or Group-owned."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Name="CreatorTypeComboBox"
                                      Grid.Column="1"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Name="CreatorIdLabel"
                                           Text="Creator ID"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,3" />
                                <TextBlock Name="CreatorIdDescLabel"
                                           Text="Your User ID or Group ID where assets will be uploaded."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ui:TextBox Name="CreatorIdTextBox"
                                        Grid.Column="1"
                                        VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
                <ui:Card Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Name="AssetCachingLabel"
                                       Text="Asset Upload Cache"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Name="AssetCachingDescLabel"
                                       Text="Roblox uploads are hashed. Subsequent conversions skip duplicate assets automatically."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ui:Button Name="ClearCacheButton"
                                   Content="Clear Cache"
                                   Icon="Delete24"
                                   Appearance="Danger"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Click="ClearCacheButton_Click" />
                    </Grid>
                </ui:Card>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Name="SaveSettingsButton"
                               Content="Save Settings"
                               Icon="Save24"
                               Appearance="Primary"
                               Click="SaveSettingsButton_Click"
                               Height="36" />
                    <ui:TextBlock Name="FeedbackText"
                                  VerticalAlignment="Center"
                                  Margin="16,0,0,0"
                                  Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                  FontWeight="SemiBold"
                                  FontSize="13" />
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
