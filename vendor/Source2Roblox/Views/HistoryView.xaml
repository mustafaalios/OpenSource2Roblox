<Page x:Class="Source2Roblox.Views.HistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="900"
      Title="HistoryView"
      Background="Transparent">

    <Grid Background="Transparent" Margin="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Name="HistoryTitleLabel"
                       Text="Conversion History"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Name="HistorySubtitleLabel"
                       Text="All past conversions are stored locally in history.json."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox Name="SearchBox"
                        Grid.Column="0"
                        PlaceholderText="Filter by map, game or type…"
                        TextChanged="SearchBox_TextChanged" />

            <ui:Button Name="OpenFileButton"
                       Grid.Column="1"
                       Content="Open history.json"
                       Icon="Document24"
                       Click="OpenFileButton_Click" />

            <ui:Button Name="ClearHistoryButton"
                       Grid.Column="3"
                       Content="Clear History"
                       Icon="Delete24"
                       Appearance="Danger"
                       Click="ClearHistoryButton_Click" />
        </Grid>

        <Border Name="StatsBar"
                Grid.Row="2"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="16,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Name="StatsTotalLabel"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0" />
                <TextBlock Name="StatsSuccessLabel"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0" />
                <TextBlock Name="StatsLastGameLabel"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Name="EmptyState"
                Grid.Row="4"
                CornerRadius="8"
                Background="#0A808080"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,48">
                <TextBlock Text="🗂"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock Name="EmptyStateLabel"
                           Text="No conversion history yet."
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Name="EmptyStateDescLabel"
                           Text="Run a conversion from the Home tab to get started."
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ListBox Name="HistoryList"
                 Grid.Row="4"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            CornerRadius="8"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid Margin="16,12,16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="36" Height="36"
                                    CornerRadius="6"
                                    Background="{Binding StatusBackground}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,14,0">
                                <TextBlock Text="{Binding StatusBadge}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <Border CornerRadius="3"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            Padding="5,1"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding DisplayType}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding DisplayTarget}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding DisplayGame}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding DisplayDuration}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="10,0,0,0"
                                               Visibility="{Binding DurationVisibility}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                            Visibility="{Binding BadgesVisibility}">
                                    <Border CornerRadius="3"
                                            Background="#1A2ECC71"
                                            Padding="5,1"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding TexturesUploadedVisibility}">
                                        <TextBlock Text="Textures ↑"
                                                   FontSize="9"
                                                   Foreground="#2ECC71" />
                                    </Border>
                                    <Border CornerRadius="3"
                                            Background="#1A3498DB"
                                            Padding="5,1"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding MeshesUploadedVisibility}">
                                        <TextBlock Text="Meshes ↑"
                                                   FontSize="9"
                                                   Foreground="#3498DB" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="11"
                                           Foreground="#E05050"
                                           Visibility="{Binding ErrorVisibility}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                                <TextBlock Text="{Binding DisplayOutputPath}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Visibility="{Binding OutputPathVisibility}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding DisplayTimestamp}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="📂"
                                               Tag="{Binding}"
                                               Click="OpenOutputButton_Click"
                                               FontSize="12"
                                               Height="28"
                                               Padding="6,0"
                                               Margin="0,0,4,0"
                                               ToolTip="Open output folder"
                                               Visibility="{Binding OutputPathVisibility}" />
                                    <ui:Button Content="Re-run"
                                               Icon="Play24"
                                               Tag="{Binding}"
                                               Click="RerunButton_Click"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
