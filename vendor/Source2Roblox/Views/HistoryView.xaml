<Page x:Class="Source2Roblox.Views.HistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="900"
      Title="HistoryView"
      Background="Transparent">

    <Grid Background="Transparent" Margin="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Title Row -->
        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Name="HistoryTitleLabel"
                       Text="Conversion History"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Name="HistorySubtitleLabel"
                       Text="All past conversions are stored locally in history.json."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Toolbar Row -->
        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Filter box -->
            <ui:TextBox Name="SearchBox"
                        Grid.Column="0"
                        PlaceholderText="Filter by map, game or type…"
                        TextChanged="SearchBox_TextChanged" />

            <!-- Open file button -->
            <ui:Button Name="OpenFileButton"
                       Grid.Column="1"
                       Content="Open history.json"
                       Icon="Document24"
                       Click="OpenFileButton_Click" />

            <!-- Clear button -->
            <ui:Button Name="ClearHistoryButton"
                       Grid.Column="3"
                       Content="Clear History"
                       Icon="Delete24"
                       Appearance="Danger"
                       Click="ClearHistoryButton_Click" />
        </Grid>

        <!-- Empty-state banner (shown when no entries) -->
        <Border Name="EmptyState"
                Grid.Row="3"
                CornerRadius="8"
                Background="#0A808080"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,48">
                <TextBlock Text="🗂"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <TextBlock Name="EmptyStateLabel"
                           Text="No conversion history yet."
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Name="EmptyStateDescLabel"
                           Text="Run a conversion from the Home tab to get started."
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- History List -->
        <ScrollViewer Grid.Row="3"
                      Name="HistoryScroll"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            <ItemsControl Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                CornerRadius="8"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid Margin="16,12,16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status badge -->
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="6"
                                        Background="{Binding StatusBackground}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="{Binding StatusBadge}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Main info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Border CornerRadius="3"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                Padding="5,1"
                                                Margin="0,0,6,0">
                                            <TextBlock Text="{Binding DisplayType}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                        <TextBlock Text="{Binding DisplayTarget}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayGame}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               FontSize="11"
                                               Foreground="#E05050"
                                               Visibility="{Binding ErrorVisibility}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Right: timestamp + re-run -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding DisplayTimestamp}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,0,6" />
                                    <ui:Button Content="Re-run"
                                               Icon="Play24"
                                               Tag="{Binding}"
                                               Click="RerunButton_Click"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
