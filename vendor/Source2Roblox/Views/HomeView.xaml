<Page x:Class="Source2Roblox.Views.HomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="900"
      Title="HomeView"
      Background="Transparent">

    <Grid Background="Transparent" Margin="28,20,28,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="340" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="2*" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Configuration Panel ===== -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Background="Transparent">

                <!-- Section Header -->
                <TextBlock Name="ConversionModeLabel"
                           Text="CONVERSION MODE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />

                <!-- Mode Selector: 4 equal buttons -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Button Name="ModeMapButton"      Content="Map"      Grid.Column="0" Margin="0,0,4,0"  Click="ModeButton_Click" Tag="map"      Appearance="Primary"    HorizontalAlignment="Stretch" Height="32" FontSize="13" />
                    <ui:Button Name="ModeModelButton"    Content="Model"    Grid.Column="1" Margin="4,0,4,0"  Click="ModeButton_Click" Tag="model"    Appearance="Secondary"  HorizontalAlignment="Stretch" Height="32" FontSize="13" />
                    <ui:Button Name="ModeTextureButton"  Content="Texture"  Grid.Column="2" Margin="4,0,4,0"  Click="ModeButton_Click" Tag="texture"  Appearance="Secondary"  HorizontalAlignment="Stretch" Height="32" FontSize="13" />
                    <ui:Button Name="ModeAdvancedButton" Content="Advanced" Grid.Column="3" Margin="4,0,0,0"  Click="ModeButton_Click" Tag="advanced" Appearance="Secondary"  HorizontalAlignment="Stretch" Height="32" FontSize="13" />
                </Grid>

                <!-- Source Game Mount Card -->
                <ui:Card Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Name="GameMountLabel"
                                   Text="Source Game Mount"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,14" />

                        <TextBlock Name="SteamSelectLabel"
                                   Text="Discovered Steam game"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,5" />
                        <ComboBox Name="GamesComboBox"
                                  SelectionChanged="GamesComboBox_SelectionChanged"
                                  Margin="0,0,0,14" />

                        <TextBlock Name="ManualSelectLabel"
                                   Text="Or enter game directory manually (folder containing gameinfo.txt)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Name="GameDirTextBox"
                                        PlaceholderText="C:/Program Files (x86)/Steam/steamapps/common/..."
                                        TextChanged="GameDirTextBox_TextChanged" />
                            <ui:Button Name="BrowseGameButton"
                                       Content="Browse"
                                       Icon="Folder24"
                                       Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Click="BrowseGameButton_Click" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Map Details Card -->
                <ui:Card Name="MapCard" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Name="MapDetailsLabel"
                                   Text="Map Details"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Name="MapDescLabel"
                                   Text="Choose a map name (e.g. d1_trainstation_01) or enter comma-separated for bulk conversion"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <ComboBox Name="MapsComboBox" IsEditable="True" />
                    </StackPanel>
                </ui:Card>

                <!-- Model Details Card -->
                <ui:Card Name="ModelCard" Padding="20" Visibility="Collapsed" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Name="ModelDetailsLabel"
                                   Text="Model Details"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Name="ModelDescLabel"
                                   Text="Enter model path/name (e.g. gman_high) or enter comma-separated for bulk conversion"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <ui:TextBox Name="ModelTextBox" PlaceholderText="models/gman.mdl" />
                    </StackPanel>
                </ui:Card>

                <!-- Texture Details Card -->
                <ui:Card Name="TextureCard" Padding="20" Visibility="Collapsed" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Name="TextureDetailsLabel"
                                   Text="VTF Texture Details"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Name="TextureDescLabel"
                                   Text="Select a VTF file path or enter comma-separated paths for bulk conversion"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Name="TextureTextBox" PlaceholderText="C:/path/to/texture.vtf" />
                            <ui:Button Name="BrowseTextureButton"
                                       Content="Browse"
                                       Icon="Document24"
                                       Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Click="BrowseTextureButton_Click" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Convert Button -->
                <ui:Button Name="RunButton"
                           Content="Convert Assets"
                           FontSize="14"
                           Height="40"
                           Icon="Play24"
                           Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           Click="RunButton_Click"
                           Margin="0,8,0,12" />

                <!-- Local Preview Card -->
                <ui:Card Name="PreviewCard" Padding="20" Visibility="Collapsed" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Name="PreviewTitleLabel"
                                   Text="Local Preview Export"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                   Margin="0,0,0,6" />
                        <TextBlock Name="PreviewDescLabel"
                                   Text="Failed uploads or local tests fall back to local Studio content folders. Open edit mode in Roblox Studio to preview."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <ui:Button Name="OpenPreviewButton"
                                   Content="Open Edit Preview"
                                   Icon="OpenFolder24"
                                   Click="OpenPreviewButton_Click" />
                        <TextBlock Name="LauncherErrorText"
                                   Foreground="Red"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Spacer column -->
        <Rectangle Grid.Column="1" />

        <!-- ===== RIGHT: Output Panel ===== -->
        <Grid Grid.Column="2" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Name="OutputTitleLabel"
                       Text="OUTPUT"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Grid.Row="0"
                       Margin="0,0,0,8" />

            <!-- Progress Indicator -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10" Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock Name="ProgressStatusText"
                           Text="Converting..."
                           FontSize="12"
                           Margin="0,0,0,5" />
                <ProgressBar Name="ConversionProgressBar" Height="4" IsIndeterminate="True" />
            </StackPanel>

            <!-- Console Output: dark terminal panel clipped to rounded corners -->
            <Border Grid.Row="2"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Background="#141414"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1">
                <TextBox Name="LogTextBox"
                         FontFamily="Consolas"
                         FontSize="11.5"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="#CCCCCC"
                         CaretBrush="#CCCCCC"
                         SelectionBrush="#3A7BD5"
                         BorderThickness="0"
                         Padding="14" />
            </Border>
        </Grid>
    </Grid>
</Page>

