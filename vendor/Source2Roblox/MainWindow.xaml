<ui:FluentWindow x:Class="Source2Roblox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="OpenSource2Roblox Studio" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        Background="Transparent"
        ExtendsContentIntoTitleBar="True"
        Icon="icon.png">

    <Grid Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="OpenSource2Roblox Studio"
                     Icon="icon.png"
                     Grid.Row="0"
                     Background="Transparent" />

        <Grid Grid.Row="1" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView Name="RootNavigation"
                               Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="True"
                               OpenPaneLength="200"
                               CompactPaneLength="52">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="Home"
                                          Icon="Home24"
                                          TargetPageTag="home"
                                          Tag="home" />
                    <ui:NavigationViewItem Content="Settings"
                                          Icon="Settings24"
                                          TargetPageTag="settings"
                                          Tag="settings" />
                    <ui:NavigationViewItem Content="History"
                                          Icon="History24"
                                          TargetPageTag="history"
                                          Tag="history" />
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Content="About"
                                          Icon="Info24"
                                          TargetPageTag="about"
                                          Tag="about" />
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <Frame Name="RootFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</ui:FluentWindow>
