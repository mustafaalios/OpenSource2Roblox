{
  "name": "source2roblox-revamp",
  "version": "0.1.0",
  "description": "A friendly Windows desktop wrapper for Source2Roblox.",
  "author": "SenorLawyer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SenorLawyer/Source2Roblox.git"
  },
  "bugs": {
    "url": "https://github.com/SenorLawyer/Source2Roblox/issues"
  },
  "homepage": "https://github.com/SenorLawyer/Source2Roblox#readme",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "bunx --bun electron-vite dev",
    "build": "bun run typecheck && bunx --bun electron-vite build",
    "typecheck": "bunx --bun tsc --noEmit",
    "test": "bun test",
    "converter:restore": "powershell -ExecutionPolicy Bypass -File scripts/build-converter.ps1 -RestoreOnly",
    "converter:build": "powershell -ExecutionPolicy Bypass -File scripts/build-converter.ps1",
    "package": "bun run build && node node_modules/electron-builder/cli.js --win --x64"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.source2roblox.revamp",
    "productName": "Source2Roblox Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/Source2Roblox/bin/Release",
        "to": "converter",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
